# Optional local-development fallback only. Do not put real production secrets here.
VITE_ADMIN_EMAIL=your-admin-email@example.com
VITE_ADMIN_PASSWORD=your-local-dev-password

# Public frontend Supabase config. Keep service-role/secret keys out of Vite env vars.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-publishable-key
